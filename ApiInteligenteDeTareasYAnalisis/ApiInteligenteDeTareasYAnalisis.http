### Variables
@baseUrl = http://localhost:5157
@contentType = application/json

###
### OBTENER TODAS LAS TAREAS
###
GET {{baseUrl}}/api/tareas
Accept: {{contentType}}

###
### CREAR UNA NUEVA TAREA (Pendiente)
###
POST {{baseUrl}}/api/tareas
Content-Type: {{contentType}}

{
  "titulo": "Implementar autenticación",
  "descripcion": "Agregar JWT al proyecto",
  "estado": "Pendiente",
  "prioridad": "Alta",
  "fechaVencimiento": "2026-06-15T00:00:00Z"
}

###
### CREAR OTRA TAREA (En Proceso)
###
POST {{baseUrl}}/api/tareas
Content-Type: {{contentType}}

{
  "titulo": "Escribir documentación",
  "descripcion": "Crear README y guía de uso",
  "estado": "EnProceso",
  "prioridad": "Media",
  "fechaVencimiento": "2026-06-30T00:00:00Z"
}

###
### CREAR TAREA CON PRIORIDAD BAJA
###
POST {{baseUrl}}/api/tareas
Content-Type: {{contentType}}

{
  "titulo": "Revisar código",
  "descripcion": "Code review de los cambios recientes",
  "estado": "Completada",
  "prioridad": "Baja",
  "fechaVencimiento": "2026-07-15T00:00:00Z"
}

###
### OBTENER TAREA POR ID (ID=1)
###
GET {{baseUrl}}/api/tareas/1
Accept: {{contentType}}

###
### OBTENER TAREA POR ID (ID=2)
###
GET {{baseUrl}}/api/tareas/2
Accept: {{contentType}}

###
### OBTENER TAREA POR ID (no existe)
###
GET {{baseUrl}}/api/tareas/999
Accept: {{contentType}}

###
### ACTUALIZAR TAREA (ID=1)
###
PUT {{baseUrl}}/api/tareas/1
Content-Type: {{contentType}}

{
  "titulo": "Implementar autenticación con OAuth",
  "descripcion": "Agregar JWT y OAuth2",
  "estado": "EnProceso",
  "prioridad": "Alta",
  "fechaVencimiento": "2026-06-20T00:00:00Z"
}

###
### ACTUALIZAR TAREA (ID=2) - Cambiar estado a Completada
###
PUT {{baseUrl}}/api/tareas/2
Content-Type: {{contentType}}

{
  "titulo": "Escribir documentación",
  "descripcion": "Documentación completada",
  "estado": "Completada",
  "prioridad": "Media",
  "fechaVencimiento": "2026-06-30T00:00:00Z"
}

